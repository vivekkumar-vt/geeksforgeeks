class Solution {
    public int findFloor(int[] arr, int x) {
        int l= 0;
        int h= arr.length - 1;
        int res=-1;

        while(l<=h){
            int mid =(l+h)/2;
            if(arr[mid]<=x){
                res=mid;
                l=mid+1;  
            } 
            else{
                h=mid-1;
            }
        }
        return res;
        
    }
}
