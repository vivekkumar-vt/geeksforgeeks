class Solution {
    public int kthSmallest(int[] arr, int k) {
        // Code here
        PriorityQueue<Integer> pq = new PriorityQueue<>(Collections.reverseOrder());
        int i=0; int n=arr.length; 
        for(i=0;i<k;i++){
            pq.offer(arr[i]);
        }
        for(i=k;i<n;i++){
            if(arr[i]>=pq.peek()){
                continue;
            }
            pq.poll();
            pq.offer(arr[i]);
        }
        return pq.peek();
    }
}
